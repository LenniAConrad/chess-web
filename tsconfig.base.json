{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@chess-web/chess-core": ["packages/chess-core/src/index.ts"],
      "@chess-web/config": ["packages/config/src/index.ts"],
      "@chess-web/db": ["packages/db/src/index.ts"]
    },
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["node"]
  }
}
